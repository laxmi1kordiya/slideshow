    // run early, and again after page load
    function restoreScrolling(){
      try{
        document.querySelectorAll('.modal-1, .modal-backdrop, .search-overlay, [data-search-modal-inner]').forEach(el=>{
          el.style.display='none';
          el.style.visibility='hidden';
          el.style.pointerEvents='none';
        });
        ['modal-open','no-scroll','search-active']
.forEach(c => document.body.classList.remove(c));

        
      }catch(e){}
    }
    // run on DOM ready, and again with a short delay (some themes add overlay after load)
    if (document.readyState === 'complete' || document.readyState === 'interactive') restoreScrolling();
    document.addEventListener('DOMContentLoaded', restoreScrolling);
    setTimeout(restoreScrolling, 1500);
  })();
</script>

