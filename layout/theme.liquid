<script>
(function () {
  'use strict';

  // --- Utilities ---
  function qs(sel, ctx) { return (ctx || document).querySelector(sel); }
  function qsa(sel, ctx) { return Array.from((ctx || document).querySelectorAll(sel || '')); }

  // Stop SVG <animateTransform> nodes (prevents rotation)
  function stopSvgAnimations(root) {
    try {
      const svgs = (root || document).querySelectorAll('svg');
      svgs.forEach(svg => {
        const anims = svg.querySelectorAll('animateTransform');
        if (anims.length) {
          anims.forEach(a => a.parentNode && a.parentNode.removeChild(a));
        }
        // Also try to stop CSS animations on the SVG or its parents
        svg.style.animation = 'none';
        svg.style.webkitAnimation = 'none';
      });
    } catch (e) { /* ignore */ }
  }

  // Force-stop CSS spinner animations for matched nodes
  function stopCssSpinner(node) {
    try {
      if (!node) return;
      node.style.animation = 'none';
      node.style.webkitAnimation = 'none';
      node.style.transition = 'none';
    } catch (e) {}
  }

  // Central cleanup function
  function cleanLoadingStates() {
    try {
      // Re-enable submit buttons inside add-to-cart forms
      qsa('form[action^="/cart/add"] button[type="submit"], form[action^="/cart/add"] [type="submit"]').forEach(btn => {
        try { btn.disabled = false; } catch(e){}
        try { btn.removeAttribute('aria-disabled'); } catch(e){}
        try { btn.classList.remove('is-loading','loading','btn-loading','loading-spinner'); } catch(e){}
      });

      // Re-enable any disabled inputs/buttons that look related to cart drawer/add
      qsa('button[disabled], input[disabled]').forEach(el => {
        if (!el.closest) return;
        if (el.closest('form[action^="/cart/add"]') || el.closest('.cart-drawer') || el.matches('[data-drawer-add], [data-cart-open], .atc-button--checkout, .atc-button--viewcart, .shopify-payment-button')) {
          try { el.disabled = false; } catch(e){}
          try { el.removeAttribute('aria-disabled'); } catch(e){}
          try { el.classList.remove('is-loading','loading','btn-loading'); } catch(e){}
        }
      });

      // Known spinner selectors to remove
      const spinnerSelectors = [
        '.spinner',
        '.loading-spinner',
        '.shopify-payment-button__spinner',
        '.global-spinner',
        '.form-spinner',
        '.ajax-loading',
        '.cart-loading',
        '.btn-spinner',
        '.atc-spinner',
        '.__injected_spinner',      // our injected spinner
        '.__detected_spinner'       // marker for detected theme spinner
      ];

      spinnerSelectors.forEach(sel => {
        qsa(sel).forEach(n => {
          try {
            // Stop any animations inside node first
            stopCssSpinner(n);
            stopSvgAnimations(n);
            n.parentNode && n.parentNode.removeChild(n);
          } catch(e){}
        });
      });

      // Also remove any stray inline SVG animateTransform elements anywhere inside buttons
      qsa('button svg animateTransform, button svg animate').forEach(a => {
        try { a.parentNode && a.parentNode.removeChild(a); } catch(e){}
      });

      // Also clear any spinner-like svg nodes inside buttons (fallback)
      qsa('button svg').forEach(svg => {
        // if the svg contains stroke-dasharray or animateTransform, remove it
        try {
          if (svg.querySelector('animateTransform') || svg.querySelector('animate')) {
            svg.parentNode && svg.parentNode.removeChild(svg);
          } else {
            // stop CSS animation as backup
            svg.style.animation = 'none';
            svg.style.webkitAnimation = 'none';
          }
        } catch(e){}
      });

      // Remove common body classes added by loading states
      ['is-loading','ajax-loading','loading','cart-loading','no-scroll','no-scroll--active'].forEach(c => {
        try { document.body.classList.remove(c); } catch(e) {}
      });

      // Also ensure any 'is-loading' class on buttons is removed
      qsa('button.is-loading, button.loading').forEach(btn => {
        try { btn.classList.remove('is-loading','loading'); } catch(e) {}
        try { btn.disabled = false; btn.removeAttribute('aria-disabled'); } catch(e) {}
        // remove injected spinner if present
        const inj = btn.querySelector('.__injected_spinner');
        if (inj) try { inj.remove(); } catch(e) {}
      });

      // Finally: stop any remaining svg animations across page just in case
      stopSvgAnimations(document);
    } catch (err) {
      console.warn('cleanLoadingStates error', err);
    }
  }

  // Add a small visible spinner only when needed — but DON'T add if any existing spinner detected.
  function setButtonLoading(btn) {
    if (!btn) return;
    try { btn.disabled = true; } catch(e){}
    try { btn.setAttribute('aria-disabled','true'); } catch(e){}
    try { btn.classList.add('is-loading'); } catch(e){}

    // If there is any existing spinner inside the button, mark it and do not inject ours.
    const existingSpinner = btn.querySelector('.spinner, .loading-spinner, .shopify-payment-button__spinner, .global-spinner, .form-spinner, .ajax-loading, .btn-spinner, .atc-spinner, svg animateTransform, svg animate');
    if (existingSpinner) {
      try { existingSpinner.classList && existingSpinner.classList.add('__detected_spinner'); } catch(e){}
      // Also stop its animation briefly so user doesn't see infinite rotate if stuck
      try { stopCssSpinner(existingSpinner); stopSvgAnimations(existingSpinner); } catch(e){}
      return;
    }

    // inject our lightweight spinner if nothing else exists
    if (!btn.querySelector('.__injected_spinner')) {
      const s = document.createElement('span');
      s.className = '__injected_spinner';
      s.style.display = 'inline-block';
      s.style.width = '18px';
      s.style.height = '18px';
      s.style.marginLeft = '8px';
      s.style.verticalAlign = 'middle';
      s.innerHTML = '<svg viewBox="0 0 50 50" style="width:18px;height:18px;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-dasharray="31.4 31.4" stroke-dashoffset="0"><animateTransform attributeName="transform" type="rotate" from="0 25 25" to="360 25 25" dur="0.9s" repeatCount="indefinite"/></circle></svg>';
      try { btn.appendChild(s); } catch(e){}
    }
  }

  // --- Patch fetch to call clean after cart fetches ---
  if (typeof window.fetch === 'function' && !window.__cart_fetch_patched) {
    const origFetch = window.fetch.bind(window);
    window.fetch = function (input, init) {
      const url = (typeof input === 'string') ? input : (input && input.url ? input.url : '');
      const isCartEndpoint = url && (url.indexOf('/cart/add') !== -1 || url.indexOf('/cart/change') !== -1 || url.indexOf('/cart.js') !== -1 || url.indexOf('/cart.json') !== -1 || url.indexOf('cart/add.js') !== -1);
      const p = origFetch(input, init);
      if (isCartEndpoint) {
        p.then(() => setTimeout(cleanLoadingStates, 80)).catch(() => setTimeout(cleanLoadingStates, 80));
      } else {
        // non-cart fetch: still remove stuck spinners occasionally
        p.then(() => setTimeout(cleanLoadingStates, 250)).catch(() => {});
      }
      return p;
    };
    window.__cart_fetch_patched = true;
  }

  // Wrap jQuery.ajax to always cleanup
  try {
    const $ = window.jQuery || window.$;
    if ($ && $.ajax && !$.ajax.__cart_wrapped) {
      const orig = $.ajax;
      $.ajax = function (...args) {
        const jq = orig.apply(this, args);
        try {
          if (jq && typeof jq.always === 'function') jq.always(() => setTimeout(cleanLoadingStates, 60));
        } catch(e){}
        return jq;
      };
      $.ajax.__cart_wrapped = true;
      $(document).off('.cart-clean').on('ajaxComplete.cart-clean', function () { setTimeout(cleanLoadingStates, 60); });
    }
  } catch(e){}

  // On form submit, visually show loading on the clicked/submit button
  document.addEventListener('submit', function (ev) {
    try {
      const form = ev.target;
      if (!form || !form.matches) return;
      if (!form.matches('form[action^="/cart/add"], form[action*="/cart/add"]')) return;
      // find button user clicked, or fallback
      let submitBtn = ev.submitter;
      if (!submitBtn) submitBtn = form.querySelector('[type="submit"], button');
      if (submitBtn) setButtonLoading(submitBtn);
      // in case scripts never finish, force cleanup after some time
      setTimeout(cleanLoadingStates, 1500);
      setTimeout(cleanLoadingStates, 4000);
    } catch(e){}
  }, true);

  // Delegated click for upsell / quick-add buttons
  document.addEventListener('click', function (e) {
    try {
      const btn = e.target.closest ? e.target.closest('[data-drawer-add], [data-drawer-add-variant], [data-variant-add], [data-add-to-cart], .upsell-add, .product-upsell__add, .add-to-cart, button.add-to-cart') : null;
      if (!btn) return;
      setButtonLoading(btn);
      setTimeout(cleanLoadingStates, 1500);
      setTimeout(cleanLoadingStates, 4000);
    } catch(e){}
  }, true);

  // MutationObserver: watch for spinners being added and clean shortly after
  if (!window.__cart_clean_observer) {
    try {
      const mo = new MutationObserver(muts => {
        let found = false;
        for (const m of muts) {
          if (m.addedNodes && m.addedNodes.length) {
            for (const n of m.addedNodes) {
              if (n.nodeType !== 1) continue;
              if (n.matches && (n.matches('.spinner') || n.matches('.loading-spinner') || n.querySelector && (n.querySelector('.spinner') || n.querySelector('.loading-spinner') || n.querySelector('animateTransform')))) {
                found = true; break;
              }
            }
          }
          if (found) break;
        }
        if (found) setTimeout(cleanLoadingStates, 120);
      });
      mo.observe(document.documentElement || document.body, { childList: true, subtree: true });
      window.__cart_clean_observer = mo;
    } catch(e){}
  }

  // run once on load
  setTimeout(cleanLoadingStates, 60);
  // expose for debugging
  try { window.cleanLoadingStates = cleanLoadingStates; } catch(e){}

})();

</script>


<script>
(function () {
  let lastVariantId = null;

  function tryInitPaymentButton() {
    const variantInput = document.querySelector('input[name="id"]');
    if (!variantInput || !variantInput.value) return;

    const variantId = variantInput.value;
    if (variantId === lastVariantId) return;

    lastVariantId = variantId;

    // Give Empire ONE frame to finish UI updates
    requestAnimationFrame(() => {
      if (window.Shopify && Shopify.PaymentButton) {
        Shopify.PaymentButton.init();
      }
    });
  }

  // 1️⃣ Empire fires this
  document.addEventListener('variant:change', tryInitPaymentButton);

  // 2️⃣ Fallback for themes that don’t emit consistently
  document.addEventListener('change', function (e) {
    if (e.target.closest('[name^="option"], .product-options, .variant-input')) {
      tryInitPaymentButton();
    }
  });
})();
</script>

