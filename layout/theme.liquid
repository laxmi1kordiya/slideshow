   <script>
document.addEventListener('DOMContentLoaded', function () {
  const header = document.querySelector('.site-header-main') || document.querySelector('.site-header');
  const panel = document.querySelector('.live-search-form__wrapper');
  const toggles = Array.from(document.querySelectorAll('[data-asset="search-button"]'));
const closeBtn = document.querySelector('[data-asset="search-modal-close"]');

  if (!header || !panel || toggles.length === 0) return;

  // If panel is currently not placed directly after header, move it there.
  // This keeps all existing event handlers attached to the same DOM node.
  const headerParent = header.parentNode;
  if (panel.parentNode !== headerParent || panel.previousElementSibling !== header) {
    // Insert panel immediately after header in the DOM
    if (header.nextSibling) headerParent.insertBefore(panel, header.nextSibling);
    else headerParent.appendChild(panel);
  }

  // Ensure the panel looks/behaves as part of page flow (CSS handles collapse)
  panel.style.position = panel.style.position || 'relative';

  function openPanel() {
    panel.classList.add('open');
    panel.setAttribute('aria-hidden', 'false');
    // focus input after animation starts
    const input = panel.querySelector('[data-live-search-input], input[type="search"], input[type="text"]');
    setTimeout(()=> input && input.focus(), 120);
  }

  function closePanel() {
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden', 'true');
    const input = panel.querySelector('[data-live-search-input], input[type="search"], input[type="text"]');
    input && input.blur();
  }



  
  // Toggle search via header search buttons
  toggles.forEach(btn => {
    btn.addEventListener('click', function (ev) {
      ev.preventDefault();
      if (panel.classList.contains('open')) closePanel();
      else openPanel();
    });
  });

  // Close via modal-close button (if present)
  if (closeBtn) closeBtn.addEventListener('click', closePanel);

  // Close on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && panel.classList.contains('open')) closePanel();
  });

  // Click outside to close (but clicking inside header does NOT close)
  document.addEventListener('click', function (e) {
    if (!panel.classList.contains('open')) return;
    const insidePanel = panel.contains(e.target);
    const clickedToggle = toggles.some(t => t.contains(e.target));
    const insideHeader = header.contains(e.target);
    if (!insidePanel && !clickedToggle && !insideHeader) closePanel();
  });

  // If the theme updates panel position via JS, re-run the move on resize
  window.addEventListener('resize', function () {
    if (panel.parentNode !== header.parentNode || panel.previousElementSibling !== header) {
      const headerParent = header.parentNode;
      if (header.nextSibling) headerParent.insertBefore(panel, header.nextSibling);
      else headerParent.appendChild(panel);
    }
  });
});
</script>
