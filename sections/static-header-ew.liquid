{% assign has_box_shadow = false %}
{% if settings.color_background == settings.color_header_background  %}
  {% assign has_box_shadow = true %}
{% endif %}

<script
  type="application/json"
  data-section-id="{{ section.id }}"
  data-section-type="static-header"
  data-section-data>
  {
    "settings": {
      "sticky_header": {{ section.settings.sticky_header | json }},
      "has_box_shadow": {{ has_box_shadow | json }},
      "live_search": {
        "enable": {{ section.settings.enable_live_search | json }},
        "enable_images": {{ section.settings.enable_live_search_images | json }},
        "enable_content": {{ section.settings.enable_live_search_articles_pages | json }},
        "money_format": {{ shop.money_format | strip_html | json }},
        "show_mobile_search_bar": {{ section.settings.show_mobile_search_bar | json }},
        "context": {
          "view_all_results": {{ 'search.general.view_all_results' | t | json }},
          "view_all_products": {{ 'search.general.view_all_products' | t | json }},
          "content_results": {
            "title": {{ 'search.general.pages_and_posts_title' | t | json }},
            "no_results": {{ 'search.general.pages_and_posts_no_results' | t | json }}
          },
          "no_results_products": {
            "title": {{ 'search.general.no_results_products_title' | t: terms: '*terms*' | json }},
            "title_in_category": {{ 'search.general.no_results_products_title_in_category' | t: terms: '*terms*', category: '*category*' | json }},
            "message": {{ 'search.general.no_results_products_message' | t | json }}
          }
        }
      }
    }
  }
</script>

{%- assign logo_height = section.settings.logo_height | default: 100 -%}
{%- assign logo_width = section.settings.logo_width | default: 200 -%}
{%- assign logo_size = logo_width | prepend: 'x' -%}
{{ 'static-header-ew.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .site-header {
    --layout-container-max-width: {{ settings.layout_max_width }}px;
  }
  .site-logo {
    max-width: {{ logo_width }}px;
  }
  .site-logo-image {
    max-height: {{ logo_height }}px;
  }
  .site-navigation-wrapper{
    background-color:{{section.settings.menu_background}};
  }
  .site-navigation{
    background-color:transparent;
    justify-content: center;
  }
  .site-navigation .navmenu-link-depth-1{
    color:{{section.settings.menu_text_color}};
    padding: 14px 15px;
  }
  @media screen and (min-width: 1024px){
    .site-header-main-content {
      margin-right:80px;
      margin-left: 0;
    }
  }
  .site-header .site-navigation .navmenu-depth-1>li {
    padding-top: 0;
    padding-bottom: 0;
  }
  .site-header li.navmenu-item{
    position:relative;
  }
  .site-header li.navmenu-item:after {
    position: absolute;
    content: "";
    height: 0;
    width: 100%;
    left: 0;
    top: 0;
    background-color: #000;
    z-index: 0;
    transition: .3s all;
  }
 .site-header li.navmenu-item:hover:after{
    height:100%;
  } 
 .site-header li.navmenu-item a,summary{
    postion:relative;
    z-index:1;
    opacity:1;
  }
  .site-header .site-navigation .navmenu-depth-1>li>a:hover, .site-navigation .navmenu-depth-1>li>a[aria-expanded=true] {
    opacity: 1;
  }
  .site-header .site-navigation .navmenu-depth-2 .navmenu-link:hover, .site-navigation .navmenu-depth-2 .navmenu-link.navmenu-active {
    color: #fff;
    position: relative;
    z-index: 1;
  }
{%- endstyle -%}

<header class="site-header site-header-nav--open static-header-ew" role="banner" data-site-header>
  <div class="site-header-main--wrapper">
    <div class="site-header-main site-header--full-width" data-site-header-main data-site-header-mobile-search-button>
    <div class="site-header-actions--wrapper left-align">
      <button class="site-header-menu-toggle" data-menu-toggle>
        <div class="site-header-menu-toggle--button" tabindex="-1">
          <span class="toggle-icon--bar toggle-icon--bar-top"></span>
          <span class="toggle-icon--bar toggle-icon--bar-middle"></span>
          <span class="toggle-icon--bar toggle-icon--bar-bottom"></span>
          <span class="visually-hidden">{{ 'general.accessibility.menu' | t }}</span>
        </div>
      </button>
      <button class="site-header-mobile-search-button hide-mobile" data-asset="search-button">
         <div class="site-header-mobile-search-button--button" tabindex="-1">
            {%- render 'icon-search' -%}
          </div>
      </button>
      <li class="site-header-actions__search-link site-header-mobile-search-button hide-desktop" >
    <button data-asset="search-button" style="border:0">
       <div class="site-header-mobile-search-button--button" tabindex="-1">
          {%- render 'icon-search' -%}
        </div>
    </button>
  </li>
    </div>
    <div class="site-header-logo">
      <a class="site-logo" href="{{ routes.root_url }}">
        {%- if section.settings.logo -%}
          {%- assign logo_alt = section.settings.logo.alt -%}
          {%- if logo_alt == blank -%}
            {%- assign logo_alt = shop.name | strip -%}
          {%- endif -%}
          {%-
            render 'rimg',
            img: section.settings.logo,
            class: 'site-logo-image',
            alt: logo_alt,
            size: logo_size,
            focal_point: section.settings.logo.presentation.focal_point,
          -%}
        {%- else -%}
          {%- if template == 'index' -%}
            <h1 class="site-logo-text">
              {{ shop.name }}
            </h1>
          {%- else -%}
            <span class="site-logo-text">
              {{ shop.name }}
            </span>
          {%- endif -%}
        {%- endif -%}
      </a>
    </div>
    <div class="site-header-actions--wrapper right-align">
      {% render 'site-header-actions' %}
    </div>
  </div>
  </div>
  <div class="site-navigation-wrapper{% if shop.customer_accounts_enabled %} site-navigation--has-actions{% endif %}{% if section.settings.full_width_header %} site-header--full-width{% endif %}" data-site-navigation id="site-header-nav">
    <nav class="site-navigation" aria-label="{{ 'general.accessibility.nav_main' | t }}">
      {%
        render 'navmenu',
        menu: section.settings.menu,
        blocks: section.blocks,
      %}

      {% if section.settings.secondary_menu != blank %}
        {%
          render 'navlist',
          menu_list: linklists[section.settings.secondary_menu].links,
          depth: 1,
          max_depth: 1,
          aria_expanded: true,
          navmenu_classes: 'site-navigation__secondary-menu',
        %}
      {% endif %}
    </nav>
  </div>

  {%- render 'site-mobile-nav', blocks: section.blocks, -%}
  <search-modal class="auto-search-modal">
      <div class="modal-1" aria-label="modal window">
          <div class="modal-inner" data-search-modal-inner>
              <div class="modal-content" data-search-modal-content>
                <div class="modal-content__wrapper">
                  <div class="live-search-form__wrapper">
                    {%-
                        render 'live-search-form',
                        quick_links: linklists[section.settings.quick_links],
                        enable_images: section.settings.enable_live_search_images,
                        enable_content: section.settings.enable_live_search_articles_pages
                    -%}
                    <button
                      class="modal-close"
                      type="button"
                      aria-label="{{ 'general.accessibility.close' | t }}"
                      data-asset="search-modal-close"
                    >
                      {%- render 'icon-menu-close' -%}
                    </button>
                  </div>
                </div>
              </div>
          </div>
      </div>
  </search-modal>
</header>
