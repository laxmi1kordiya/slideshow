{%- comment -%}
  Cart Drawer
  - Heading: "Your Beautiful Picks"
  - Product grid: image, name, variants, price, qty adjustment
  - Footer: Total + note + centered checkout button + cross-sell + free-shipping banner
{%- endcomment -%}

<div id="CartDrawerOverlay" class="cart-drawer__overlay"></div>

<aside
  id="CartDrawer"
  class="cart-drawer cart-drawer--right"
  role="dialog"
  aria-modal="true"
  aria-labelledby="CartDrawerTitle"
>
  <header class="cart-drawer__header">
    <h2 id="CartDrawerTitle" class="cart-drawer__title">Your Beautiful Picks</h2>
    <button
      type="button"
      class="cart-drawer__close"
      aria-label="Close cart"
      data-cart-drawer-close
    >
      ×
    </button>
  </header>

  <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-drawer__form">
    {% if cart.item_count == 0 %}
      <div class="cart-drawer__empty cart-drawer__empty--center">
        <p class="cart-drawer__empty-message">
          Your cart is currently empty.
        </p>
        <a href="https://www.monsterpiercing.com/collections/new-arrivals" class="cart-drawer__empty-btn">
          Shop your next look
        </a>
      </div>
    {% else %}

{%- assign free_shipping_threshold = 2000 -%}
{%- assign subtotal = cart.items_subtotal_price | default: 0 -%}
{%- assign remaining = free_shipping_threshold | minus: subtotal -%}
{%- assign pct = 0 -%}

{%- if free_shipping_threshold > 0 -%}
  {%- assign pct = subtotal | times: 100 | divided_by: free_shipping_threshold -%}
  {%- if pct > 100 -%}{%- assign pct = 100 -%}{%- endif -%}
{%- endif -%}

<div class="free-shipping-banner" role="status" aria-live="polite" aria-atomic="true">

  {% if cart.currency.iso_code == 'GBP' %}

    {% if remaining > 0 %}
      <div class="free-shipping-banner__inner">
        <span class="free-shipping-banner__text">
          <strong><span class="money">{{ remaining | money }}</span></strong> away from free UK shipping
        </span>
      </div>
    {% else %}
      <div class="free-shipping-banner__inner free-shipping-banner__inner--eligible">
        <span class="free-shipping-banner__text">
          You’re eligible for <strong>free UK shipping!</strong>
        </span>
      </div>
    {% endif %}

  {% else %}

    <div class="free-shipping-banner__inner">
      <span class="free-shipping-banner__text">
        Shipping calculated at checkout🙂
      </span>
    </div>

  {% endif %}

</div>


      <ul class="cart-drawer__items" role="list">
        {% for item in cart.items %}
          <li class="cart-drawer__item" data-line="{{ forloop.index }}">
            <a href="{{ item.url }}" class="cart-drawer__image-wrapper">
              {%- comment -%} Robust safe image output {%- endcomment -%}
              {%- assign image_obj = item.image | default: item.product.featured_image -%}
              {% if image_obj %}
                <img
                  src="{{ image_obj | img_url: '200x' }}"
                  srcset="{{ image_obj | img_url: '120x' }} 1x, {{ image_obj | img_url: '240x' }} 2x, {{ image_obj | img_url: '360x' }} 3x"
                  alt="{{ image_obj.alt | default: item.product.title | escape }}"
                  class="cart-drawer__image"
                  loading="lazy"
                >
              {% else %}
                <img src="{{ 'placeholder.png' | asset_url }}" alt="{{ item.product.title | default: 'Product' | escape }}" class="cart-drawer__image" loading="lazy">
              {% endif %}
            </a>

            <div class="cart-drawer__item-main">
              <a href="{{ item.url }}" class="cart-drawer__item-title">
                {{ item.product.title }}
              </a>

              {% unless item.product.has_only_default_variant %}
                <div class="cart-drawer__item-variant">
                  {{ item.variant.title }}
                </div>
              {% endunless %}

              {% if item.selling_plan_allocation %}
                <div class="cart-drawer__item-selling-plan">
                  {{ item.selling_plan_allocation.selling_plan.name }}
                </div>
              {% endif %}

              <div class="cart-drawer__item-meta">
                <div class="cart-drawer__qty">
                  <button type="button" class="cart-drawer__qty-btn" data-qty-change="decrease" data-line="{{ forloop.index }}">−</button>
                  <input class="cart-drawer__qty-input" type="number" min="0" name="updates[]" value="{{ item.quantity }}" data-line-input="{{ forloop.index }}">
                  <button type="button" class="cart-drawer__qty-btn" data-qty-change="increase" data-line="{{ forloop.index }}">+</button>
                </div>

                <div class="cart-drawer__price">
                  <span class="bcpo-cart-item-line-price" data-key="{{item.key}}">{{ item.final_price | money }}</span>
                  {% if item.original_line_price > item.final_line_price %}
                    <span class="cart-drawer__price-original"><span class="bcpo-cart-item-line-price" data-key="{{item.key}}"><span class="bcpo-cart-item-original-price" data-key="{{item.key}}">{{ item.original_price | money }}</span></span></span>
                  {% endif %}
                </div>
              </div>
            </div>
          </li>
        {% endfor %}
      </ul>


      {%- comment -%}
        Cross-sell / recommended products
      {%- endcomment -%}
      {%- assign show_cross_sells = false -%}
      {%- assign rec_products = nil -%}

      {%- if cart.item_count > 0 -%}
        {%- assign first_item = cart.items.first -%}
        {%- if first_item and first_item.product -%}
          {%- assign rec_products = first_item.product.recommendations | default: nil -%}
          {%- if rec_products and rec_products.size > 0 -%}
            {%- assign show_cross_sells = true -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- if show_cross_sells == false -%}
        {%- assign fallback_collection = collections['jewellery-piercing-aftercare'] -%}
        {%- if fallback_collection and fallback_collection.products.size > 0 -%}
          {%- assign rec_products = fallback_collection.products -%}
          {%- assign show_cross_sells = true -%}
        {%- endif -%}
      {%- endif -%}

      {%- if show_cross_sells and rec_products -%}
        <div class="cart-drawer__cross-sell" aria-label="Recommended products">
          <h3 class="cart-drawer__cross-sell-title">Complete Your Monster Kit: Care & Clean Essentials.</h3>
          <div class="cart-drawer__cross-sell-list">
            {%- for p in rec_products limit:7 -%}
              <div class="cart-drawer__cross-item" data-product-id="{{ p.id }}" data-variant-id="{{ p.variants.first.id }}">
                <a href="{{ p.url }}" class="cart-drawer__cross-image" title="{{ p.title }}">
                  {% if p.featured_image %}
                    <img src="{{ p.featured_image | img_url: '200x' }}" alt="{{ p.featured_image.alt | escape }}">
                  {% else %}
                    <span class="cart-drawer__cross-image--placeholder" aria-hidden="true"></span>
                  {% endif %}
                </a>

                <div class="cart-drawer__cross-meta">
                  <a class="cart-drawer__cross-title" href="{{ p.url }}">{{ p.title | truncate: 50 }}</a>

                  <div class="cart-drawer__cross-actions">
                    <button
                      class="cart-drawer__cross-add button-secondary"
                      type="button"
                      data-drawer-add
                      data-variant-id="{{ p.variants.first.id }}"
                      aria-label="Add {{ p.title }} to cart">
                      Add
                    </button>

                    <div class="cart-drawer__cross-inline-price">
                      {% if p.price_varies %}
                        <span class="money">{{ p.price_min | money }}</span>
                      {% else %}
                        <span class="money">{{ p.price | money }}</span>
                      {% endif %}
                    </div>
                  </div>

                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <footer class="cart-drawer__footer">
        <div class="cart-drawer__row cart-drawer__total">
          <span class="cart-drawer__label">Total</span>
          <span class="cart-drawer__value"><span class="bcpo-cart-original-total">{{ cart.total_price | money }}</span></span>
        </div>

        <p class="cart-drawer__note" aria-hidden="false">
          Coupons apply at checkout.
        </p>

        <div class="cart-drawer__checkout-wrap">
          <a href="/checkout" class="cart-drawer__checkout-btn">Checkout</a>
        </div>
      </footer>

    {% endif %}
  </form>
</aside>

<!-- bcpo done -->