    });
    
    // Attach listeners to all existing checkboxes immediately
    attachEventListenersToCheckboxes();
    
    // Also add a global observer to catch any dynamically added checkboxes
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.type === 'childList') {
          mutation.addedNodes.forEach(function(node) {
            if (node.nodeType === 1) { // Element node
              // Check if the added node is a checkbox or contains checkboxes
              if (node.classList && node.classList.contains('product-checkbox')) {
                console.log('[Observer] New checkbox detected, attaching listeners');
                node.addEventListener("change", handleProductCheckboxChange);
                node.addEventListener("click", handleProductCheckboxChange);
              }
              // Check for checkboxes within the added node
              const checkboxes = node.querySelectorAll && node.querySelectorAll('.product-checkbox');
              if (checkboxes && checkboxes.length > 0) {
                console.log('[Observer] New checkboxes detected in node, attaching listeners');
                checkboxes.forEach(cb => {
                  cb.addEventListener("change", handleProductCheckboxChange);
                  cb.addEventListener("click", handleProductCheckboxChange);
                });
              }
            }
          });
        }
      });
    });
    
    // Start observing
    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
    
    // Multiple fallbacks to ensure everything works
    setTimeout(() => {
      console.log('[Recommendation] Fallback 1 - reattaching listeners and checking selections');
      attachEventListenersToCheckboxes();
      updateRecommendationKit();
    }, 500);
    
    setTimeout(() => {
