    // Function to attach event listeners to all existing checkboxes
    function attachEventListenersToCheckboxes() {
      console.log('[Event Setup] Attaching listeners to all checkboxes');
      const allCheckboxes = document.querySelectorAll('.product-checkbox');
      console.log('[Event Setup] Found', allCheckboxes.length, 'checkboxes');
      
      allCheckboxes.forEach((checkbox, index) => {
        console.log(`[Event Setup] Attaching to checkbox ${index + 1}:`, checkbox.getAttribute('data-name'));
        
        // Remove existing listeners first to avoid duplicates
        checkbox.removeEventListener('change', handleProductCheckboxChange);
        checkbox.removeEventListener('click', handleProductCheckboxChange);
        
        // Add new listeners
        checkbox.addEventListener('change', handleProductCheckboxChange);
        checkbox.addEventListener('click', handleProductCheckboxChange);
      });
    }

    // BULLETPROOF event listeners - add to multiple places to ensure we catch everything
    document.addEventListener("change", handleProductCheckboxChange);
    document.addEventListener("click", handleProductCheckboxChange);
    
    // Also add to the subscription section specifically
    const subscriptionSection = document.getElementById('subscription-section');
    if (subscriptionSection) {
      subscriptionSection.addEventListener("change", handleProductCheckboxChange);
      subscriptionSection.addEventListener("click", handleProductCheckboxChange);
    }
    
    // Add to all product cards as well
    document.querySelectorAll('.product-card').forEach(card => {
