    function updateSubscriptionWidget() {
      const productCount = Object.keys(selectedProducts).length;
      console.log("updateSubscriptionWidget called, productCount:", productCount);
      
      if (productCount === 0) {
        subscriptionWidgetContainer.style.display = "none";
        console.log("No products selected, hiding widget");
        return;
      }
  
      subscriptionWidgetContainer.style.display = "block";
      console.log("Products selected, showing widget");
  
      // Calculate total regular price across ALL selected products
      let totalRegularPrice = 0;
      Object.values(selectedProducts).forEach(prod => {
        totalRegularPrice += prod.price / 100;
      });
  
      // Update regular/subscription price labels if present in DOM
      if (typeof regularPriceEl !== 'undefined' && regularPriceEl) {
        regularPriceEl.textContent = `$${totalRegularPrice.toFixed(2)} each`;
      }
      if (typeof subscriptionPriceEl !== 'undefined' && subscriptionPriceEl) {
        subscriptionPriceEl.textContent = `from $${totalRegularPrice.toFixed(2)} /each`;
      }
  
      // Always build frequency options when products are selected
      console.log("Building frequency options...");
      buildFrequencyOptions();
  
      // Update subscription summary
      console.log("Updating subscription summary...");
      updateSubscriptionSummary();
    }
  
    function buildFrequencyOptions() {
      const frequencyOptions = document.getElementById("frequency-options");
      console.log("buildFrequencyOptions called, frequencyOptions element:", frequencyOptions);
      if (!frequencyOptions) return;
  
      frequencyOptions.innerHTML = "";
      if (!sellingPlans || sellingPlans.length === 0) return;
  
      // Build dropdown options (names only, no prices)
      const plansById = {};
      const optionHtml = sellingPlans.map((plan, idx) => {
        plansById[plan.id] = plan;
        return `<option value="${plan.id}" ${idx===0?'selected':''}>${plan.name}</option>`;
      }).join('');
  
      // Render a bare select (no extra wrappers/labels)
      frequencyOptions.innerHTML = `<select id="frequency-select" name="options[Select Subscription Term:]" style="width:100%;padding:10px 12px;border:1px solid #e0e0e0;border-radius:8px;font-size:14px;background:#fff;cursor:pointer;">
        ${optionHtml}
      </select>`;
  
      // Helper to set selected plan + refresh
      function setPlanFromId(planId){
        const chosen = plansById[planId];
        if (!chosen) return;
        let discountAmount = 0; let originalPrice = 0;
        Object.values(selectedProducts).forEach(prod => {
          originalPrice += prod.price / 100;
          (chosen.price_adjustments || []).forEach(adj => {
            if (adj.value_type === 'fixed_amount') discountAmount += adj.value / 100;
            if (adj.value_type === 'percentage') discountAmount += (prod.price / 100) * (adj.value / 100);
          });
        });
        window.selectedFrequencyPlan = {
          id: chosen.id,
          name: chosen.name,
          finalPrice: originalPrice - discountAmount,
          originalPrice: originalPrice,
          price_adjustments: chosen.price_adjustments || []
        };
        if (window.updateProductPricesInUI) window.updateProductPricesInUI();
        updateSubscriptionSummary();
      }
  
      const selectEl = document.getElementById('frequency-select');
      setPlanFromId(selectEl.value); // initialize
      selectEl.addEventListener('change', function(){ setPlanFromId(this.value); });
    }
  
    function updateSubscriptionSummary() {
      // Delivery frequency container may not exist anymore; use dropdown presence instead
      if (window.selectedFrequencyPlan) {
        subscriptionSummary.style.display = "block";
        const plan = window.selectedFrequencyPlan;
        summaryText.textContent = `Your subscription payment will be $${plan.finalPrice.toFixed(2)} Auto-renews, skip or cancel anytime.`;
      } else {
        subscriptionSummary.style.display = "none";
      }
    }

  // Helper: get selected checkboxes for "Other Products" using robust filtering (no CSS "i" modifier)
  function getSelectedOtherProductCheckboxes() {
    const all = Array.from(document.querySelectorAll('.product-checkbox'));
    return all.filter(cb => {
      const cat = (cb.getAttribute('data-category') || '').toLowerCase();
      const isExcluded = cat.includes('emergency oxygen') || cat.includes('aed product') || cat.includes('emergency station');
      const isOther = cat.includes('other') || cat.includes('select other');
      return cb.checked && !isExcluded && (isOther || !isExcluded);
    });
  }

  // Recommendation logic based on "Select Other Products" kit entries
  function updateRecommendationKit() {
    console.log('[Recommendation] ===== updateRecommendationKit called =====');
    
    const containerId = 'recommendation-kit-section';
    let container = document.getElementById(containerId);
    if (!container) {
      console.log('[Recommendation] Creating new container');
      container = document.createElement('div');
      container.id = containerId;
      container.style.margin = '16px 0';
      // insert after the Other Products section if present
      const otherSection = document.querySelector('.category-section[data-category*="Other Products"]');
      if (otherSection && otherSection.parentNode) {
        otherSection.parentNode.insertBefore(container, otherSection.nextSibling);
        console.log('[Recommendation] Container inserted after Other Products section');
      } else {
        document.getElementById('subscription-section').appendChild(container);
        console.log('[Recommendation] Container appended to subscription section');
      }
    } else {
      console.log('[Recommendation] Using existing container');
    }

    // Get selected products from "Other Products" category (robust)
    let selectedCheckboxes = getSelectedOtherProductCheckboxes();
    console.log('[Recommendation] Found', selectedCheckboxes.length, 'selected products (robust)');
    // Fallback to CSS attribute selector if robust path yields zero
    if (selectedCheckboxes.length === 0) {
      const cssFallback = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]:checked');
      if (cssFallback && cssFallback.length > 0) {
        selectedCheckboxes = Array.from(cssFallback);
        console.log('[Recommendation] Fallback selector found', selectedCheckboxes.length, 'selected products');
      }
    }
    
    if (selectedCheckboxes.length === 0) {
      console.log('[Recommendation] Still no selections detected; leaving container hidden');
      container.style.display = 'none';
      return;
    }

    // Calculate total size using the working fallback logic
    let totalSize = 0;
    selectedCheckboxes.forEach((cb) => {
      const name = cb.getAttribute('data-name');
      let size = 0;
      if (name.toLowerCase().includes('narcan') || name.toLowerCase().includes('overdose')) {
        size = 0.5;
      } else if (name.toLowerCase().includes('bleed')) {
        size = 1.0;
      } else if (name.toLowerCase().includes('allergy')) {
        size = 0.5;
      } else if (name.toLowerCase().includes('fire')) {
        size = 1.0;
      } else {
        size = 1.0;
      }
      totalSize += size;
      console.log('[Recommendation]', name, '= size', size);
    });

    // If size is still zero but we do have selections, default each selection to size=1
    if (totalSize <= 0 && selectedCheckboxes.length > 0) {
      totalSize = selectedCheckboxes.length;
      console.log('[Recommendation] Fallback total size by count:', totalSize);
    }
    console.log('[Recommendation] Total size:', totalSize);

    // Simple recommendation logic
    let recommendedTitle = '';
    if (selectedCheckboxes.length >= 1 && totalSize <= 0) {
      // Guard: at least one selected but size could not be derived → HERO3
      recommendedTitle = 'HERO3 Emergency Station';
    } else if (totalSize <= 1) {
      recommendedTitle = 'HERO3 Emergency Station';
    } else if (totalSize <= 2) {
      recommendedTitle = 'HERO4 Emergency Station';
    } else if (totalSize <= 3) {
      recommendedTitle = 'HERO5-F Emergency Station';
    } else {
      recommendedTitle = 'HERO6 Emergency Station';
    }

    console.log('[Recommendation] Recommended:', recommendedTitle);

    if (recommendedTitle === '') {
      console.log('No recommendation found, hiding container');
      container.innerHTML = '';
      container.style.display = 'none';
      return;
    }

    // Try to locate matching Emergency Station product info from collection (inlined below)
    let stations = [
      {% assign sep = '' %}
      {% for p in collections['aed-subscription-plan'].products %}
        {% assign title_l = p.title | downcase %}
        {% if title_l contains 'emergency station' %}
          {{ sep }}{ "title": {{ p.title | json }}, "variant_id": {{ p.variants.first.id | json }}, "price": {{ p.price | json }}, "image": {{ p.featured_image | image_url: width: 200 | json }} }
          {% assign sep = ',' %}
        {% endif %}
      {% endfor %}
    ];
    
    // DOM fallback: if collection did not return stations, read them from the rendered Emergency Station cards
    if (!stations || stations.length === 0) {
      const stationCards = document.querySelectorAll('.category-section[data-category*="Emergency Station" i] .sub-product');
      stations = Array.from(stationCards).map(card => {
        const input = card.querySelector('.product-checkbox');
        const img = card.querySelector('img');
        return {
          title: input ? input.getAttribute('data-name') : '',
          variant_id: input ? Number(input.getAttribute('data-id')) : null,
          price: input ? Number(input.getAttribute('data-price')) : 0,
          image: img ? img.getAttribute('src') : ''
        };
      }).filter(s => (s.title || '').toLowerCase().includes('emergency station'));
      console.log('[Recommendation] DOM fallback stations:', stations.map(s => s.title));
    }
    // Find by exact title, then by partial match (handles variants like HERO4 Emergency Station - Wall Mount)
    const recKey = recommendedTitle.toLowerCase();
    let prod = stations.find(s => (s.title || '').toLowerCase() === recKey);
    if (!prod) {
      prod = stations.find(s => (s.title || '').toLowerCase().includes(recKey));
    }
    if (!prod) {
      // Fallback: match by core token like 'hero3', 'hero4', 'hero5', 'hero6'
      const token = (recKey.match(/hero\d+/) || [recKey])[0];
      prod = stations.find(s => (s.title || '').toLowerCase().includes(token));
    }
    console.log('[Recommendation] Product lookup for', recommendedTitle, '=>', prod ? prod.title : 'NOT FOUND');
    if (!prod) {
      container.style.display = 'none';
      return;
    }
    const priceDollars = (prod.price || 0) / 100;
    container.style.display = 'block';
    container.innerHTML = `<h2 style="margin:16px 0 12px 0;font-size:18px;font-weight:600;">Recommended Kit</h2>
      <div style="display:flex;gap:12px;align-items:center;border:2px solid #007bff;border-radius:8px;padding:12px;background:#f8f9fa;">
        <input type="radio" 
               name="recommended-kit" 
               value="${prod.variant_id}" 
               data-variant-id="${prod.variant_id}"
               data-product-title="${prod.title}"
               data-product-price="${prod.price}"
               data-product-image="${prod.image}"
               checked 
               style="width:20px;height:20px;margin:0;">
        <img src="${prod.image}" alt="${prod.title}" style="width:64px;height:64px;object-fit:cover;border:1px solid #f0f0f0;border-radius:6px;"/>
        <div style="flex:1;">
          <div style="font-weight:600;margin-bottom:4px;">${prod.title}</div>
          <div style="color:#28a745;font-weight:600;">$${priceDollars.toFixed(2)}</div>
        </div>
      </div>`;
    
    // Remove any previously added recommended products from cart and add the new one
    const currentRecommendedRadio = document.querySelector('input[name="recommended-kit"]:checked');
    if (currentRecommendedRadio) {
      const oldVariantId = currentRecommendedRadio.getAttribute('data-variant-id');
      if (oldVariantId && oldVariantId !== prod.variant_id.toString()) {
        // Remove old recommended product from cart
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: oldVariantId, quantity: 0 })
        }).then(() => {
          // Add new recommended product to cart
          addProductToCart(prod.variant_id, 1);
        });
      } else if (oldVariantId !== prod.variant_id.toString()) {
        // Add new recommended product to cart
        addProductToCart(prod.variant_id, 1);
      }
    } else {
      // No previous recommendation, just add the new one
      addProductToCart(prod.variant_id, 1);
      }
    }
  
    // Add direct click handler to subscription radio button
    const subscriptionRadio = document.querySelector('input[name="purchase-option"][value="subscription"]');
    if (subscriptionRadio) {
      subscriptionRadio.addEventListener('click', function() {
        console.log("Subscription radio button clicked directly");
        setTimeout(() => {
          const deliveryFrequency = document.getElementById("delivery-frequency");
          if (deliveryFrequency) {
            deliveryFrequency.style.display = "block";
            console.log("Direct click: showing delivery frequency section");
          }
        }, 100);
      });
    }
  
    // Initialize Emergency Station visibility
    function updateEmergencyStationVisibility() {
      const emergencyStationSection = document.querySelector('.category-section[data-category*="Emergency Station"]');
      const otherProductsSection = document.querySelector('.category-section[data-category*="Other Products"]');
      const aedSelected = document.querySelector('.product-checkbox[data-category*="AED Product"]:checked');
      const emergencyOxygenSelected = document.querySelector('.product-checkbox[data-category*="Emergency Oxygen"]:checked');

      const shouldShow = !!(aedSelected && emergencyOxygenSelected);

      if (emergencyStationSection) {
        emergencyStationSection.style.display = shouldShow ? 'block' : 'none';
      }
      if (otherProductsSection) {
        otherProductsSection.style.display = shouldShow ? 'block' : 'none';
      }
    }
  
    // Add event listener for Purchase Option changes
    document.addEventListener('change', function(e) {
      if (e.target.name === 'purchase-option') {
        console.log('Purchase Option changed to:', e.target.value);
        // Update prices when Purchase Option changes
        if (window.updateProductPricesInUI) {
          window.updateProductPricesInUI();
        }
      }
    });
  
    // Make functions globally accessible for debugging
    window.updateRecommendationKit = updateRecommendationKit;
    window.updateEmergencyStationVisibility = updateEmergencyStationVisibility;
    window.attachEventListenersToCheckboxes = attachEventListenersToCheckboxes;
    
    // Global function to force everything to work
    window.forceRecommendationSystem = function() {
      console.log('=== FORCING RECOMMENDATION SYSTEM ===');
      attachEventListenersToCheckboxes();
      updateRecommendationKit();
      console.log('Recommendation system forced to work!');
    };
    
    // Simple test function for debugging
    window.testRecommendation = function() {
      console.log('=== TESTING RECOMMENDATION ===');
      const checkboxes = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]:checked');
      console.log('Found', checkboxes.length, 'checked products');
      
      let totalSize = 0;
      checkboxes.forEach((cb, i) => {
        const name = cb.getAttribute('data-name');
        let size = 0;
        if (name.toLowerCase().includes('narcan') || name.toLowerCase().includes('overdose')) {
          size = 0.5;
        } else if (name.toLowerCase().includes('bleed')) {
          size = 1.0;
        } else if (name.toLowerCase().includes('allergy')) {
          size = 0.5;
        } else if (name.toLowerCase().includes('fire')) {
          size = 1.0;
        } else {
          size = 1.0;
        }
        totalSize += size;
        console.log(`Product ${i+1}: ${name} = size ${size}`);
      });
      
      console.log('Total size:', totalSize);
      
      let recommendedTitle = '';
      if (totalSize <= 1) {
        recommendedTitle = 'HERO3 Emergency Station';
      } else if (totalSize <= 2) {
        recommendedTitle = 'HERO4 Emergency Station';
      } else if (totalSize <= 3) {
        recommendedTitle = 'HERO5-F Emergency Station';
      } else {
        recommendedTitle = 'HERO6 Emergency Station';
      }
      
      console.log('Should recommend:', recommendedTitle);
      
      // Force call the function
      updateRecommendationKit();
      
      return { totalSize, recommendedTitle, productCount: checkboxes.length };
    };
    
    // Force update recommendation - use this if automatic doesn't work
    window.forceRecommendation = function() {
      console.log('=== FORCING RECOMMENDATION UPDATE ===');
      updateRecommendationKit();
    };
    
    // Check all checkboxes and force update
    window.checkAllRecommendations = function() {
      console.log('=== CHECKING ALL RECOMMENDATIONS ===');
      const allCheckboxes = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]');
      console.log('Found', allCheckboxes.length, 'total Other Products checkboxes');
      
      allCheckboxes.forEach((cb, i) => {
        console.log(`Checkbox ${i+1}: ${cb.getAttribute('data-name')} - Checked: ${cb.checked}`);
      });
      
      const checked = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]:checked');
      console.log('Checked count:', checked.length);
      
      updateRecommendationKit();
    };
    
    // Debug function to check metafields
    window.debugMetafields = function() {
      const checkboxes = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]:checked');
      console.log('Found', checkboxes.length, 'checked items');
      checkboxes.forEach((cb, i) => {
        const name = cb.getAttribute('data-name');
        const allmeta = cb.getAttribute('data-allmeta');
        console.log(`Item ${i}: ${name}`);
        console.log('Raw metafields:', allmeta?.slice(0, 300) + '...');
        if (allmeta) {
          try {
            const meta = JSON.parse(allmeta);
            console.log('Parsed metafields:', meta);
            if (meta && meta.custom && meta.custom.emergency_station) {
              console.log('Emergency station data:', meta.custom.emergency_station);
            }
          } catch(e) {
            console.log('Failed to parse JSON:', e);
          }
        }
      });
    };
    
    // Simple test function to show recommendation
    window.testRecommendation = function() {
      const checkboxes = document.querySelectorAll('.product-checkbox[data-category*="Other Products" i]:checked');
      let totalSize = 0;
      checkboxes.forEach((cb) => {
        const name = cb.getAttribute('data-name');
        let size = 0;
        if (name.toLowerCase().includes('narcan') || name.toLowerCase().includes('overdose')) {
          size = 0.5;
        } else if (name.toLowerCase().includes('bleed')) {
          size = 1.0;
        } else if (name.toLowerCase().includes('allergy')) {
          size = 0.5;
        } else if (name.toLowerCase().includes('fire')) {
          size = 1.0;
        } else {
          size = 1.0;
        }
        totalSize += size;
      });
      
      console.log('Total size:', totalSize);
      
      // Simple recommendation logic
      let recommendedTitle = '';
      if (totalSize <= 1) {
        recommendedTitle = 'HERO3 Emergency Station';
      } else if (totalSize <= 2) {
        recommendedTitle = 'HERO4 Emergency Station';
      } else if (totalSize <= 3) {
        recommendedTitle = 'HERO5-F Emergency Station';
      } else {
        recommendedTitle = 'HERO6 Emergency Station';
      }
      
      console.log('Recommended:', recommendedTitle);
      
      // Create recommendation section
      const container = document.getElementById('recommendation-kit-section') || document.createElement('div');
      container.id = 'recommendation-kit-section';
      container.innerHTML = `
        <h2 style="margin:16px 0 12px 0;font-size:18px;font-weight:600;">Recommended Kit</h2>
        <div style="display:flex;gap:12px;align-items:center;border:2px solid #007bff;border-radius:8px;padding:12px;background:#f8f9fa;">
          <input type="radio" name="recommended-kit" value="test" checked style="width:20px;height:20px;margin:0;">
          <div style="flex:1;">
            <div style="font-weight:600;margin-bottom:4px;">${recommendedTitle}</div>
            <div style="color:#28a745;font-weight:600;">Based on total size: ${totalSize}</div>
          </div>
        </div>
      `;
      container.style.display = 'block';
      
      // Insert after "Select Other Products" section
      const otherSection = document.querySelector('.category-section[data-category*="Other Products"]');
      if (otherSection && otherSection.parentNode) {
        otherSection.parentNode.insertBefore(container, otherSection.nextSibling);
      }
      
      return recommendedTitle;
    };
  
    // Initialize
    updateSubscriptionWidget();
    updateEmergencyStationVisibility();
    updateRecommendationKit();

    // Removed periodic poller: run only on user selection changes

    // Ensure it also initializes when Shopify reloads sections in the Customizer or on dynamic loads
    document.addEventListener('shopify:section:load', function(){
      console.log('[Recommendation] shopify:section:load fired');
      if (window.attachEventListenersToCheckboxes) window.attachEventListenersToCheckboxes();
      if (window.updateRecommendationKit) window.updateRecommendationKit();
    });
    document.addEventListener('shopify:section:select', function(){
      console.log('[Recommendation] shopify:section:select fired');
      if (window.attachEventListenersToCheckboxes) window.attachEventListenersToCheckboxes();
      if (window.updateRecommendationKit) window.updateRecommendationKit();
    });
    document.addEventListener('shopify:section:reorder', function(){
      console.log('[Recommendation] shopify:section:reorder fired');
      if (window.attachEventListenersToCheckboxes) window.attachEventListenersToCheckboxes();
      if (window.updateRecommendationKit) window.updateRecommendationKit();
    });
  });
  </script>
  
  