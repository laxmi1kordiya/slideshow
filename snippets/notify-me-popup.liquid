{%- comment -%}
  Notify Me Popup - Back in Stock Notification
  Uses same form structure as newsletter form that creates customers
{%- endcomment -%}

{%- liquid
  assign current_variant = variant | default: product.selected_or_first_available_variant
  assign product_handle = product.handle
  assign variant_id = current_variant.id
  assign variant_title = current_variant.title | default: product.title
  assign notify_tag = 'notify-' | append: product_handle | append: '-' | append: variant_id
  assign unique_id = 'notify-' | append: section.id | append: '-' | append: product.id
-%}

<style>
  .notify-popup-overlay {
    position: fixed; inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 999; opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .notify-popup-overlay.active { opacity: 1; visibility: visible; }

  .notify-popup {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    background-color: #fff; border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    width: 90%; max-width: 420px; max-height: 90vh;
    overflow-y: auto; z-index: 1000;
    opacity: 0; visibility: hidden;
    transition: all 0.3s ease;
  }
  .notify-popup.active { opacity: 1; visibility: visible; transform: translate(-50%, -50%) scale(1); }

  .notify-popup__header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 1.5rem; border-bottom: 1px solid #e5e5e5;
  }
  .notify-popup__title { margin: 0; font-size: 1.125rem; font-weight: 600; }
  .notify-popup__close {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    background: none; border: none; cursor: pointer; border-radius: 50%;
  }
  .notify-popup__close:hover { background-color: #f5f5f5; }
  .notify-popup__close svg { width: 20px; height: 20px; stroke: #666; }

  .notify-popup__body { padding: 1.5rem; }
  .notify-popup__product {
    display: flex; gap: 1rem;
    padding-bottom: 1.25rem; margin-bottom: 1.25rem;
    border-bottom: 1px solid #e5e5e5;
  }
  .notify-popup__product-image {
    width: 70px; height: 70px;
    object-fit: cover; border-radius: 6px; background-color: #f5f5f5;
  }
  .notify-popup__product-title { margin: 0 0 0.25rem; font-size: 0.9375rem; font-weight: 600; }
  .notify-popup__product-variant { margin: 0; font-size: 0.8125rem; color: #666; }
  .notify-popup__description { margin: 0 0 1.25rem; font-size: 0.875rem; color: #444; line-height: 1.5; }

  .notify-popup .newsletter-form__field-wrapper { margin-bottom: 1rem; }
  .notify-popup .field { position: relative; }
  .notify-popup .field__input {
    width: 100%; padding: 0.75rem 1rem;
    font-size: 1rem; border: 1px solid #ccc; border-radius: 6px;
    box-sizing: border-box;
  }
  .notify-popup .field__input:focus { outline: none; border-color: #000; box-shadow: 0 0 0 3px rgba(0,0,0,0.1); }
  .notify-popup .field__label {
    display: block; font-size: 0.8125rem; font-weight: 500; margin-bottom: 0.375rem;
  }

  .notify-popup__submit {
    width: 100%; padding: 0.875rem 1.5rem;
    font-size: 0.9375rem; font-weight: 600;
    color: #fff; background-color: #000;
    border: none; border-radius: 6px; cursor: pointer;
    margin-top: 1rem;
  }
  .notify-popup__submit:hover:not(:disabled) { opacity: 0.85; }

  .notify-popup__privacy { font-size: 0.75rem; color: #888; text-align: center; margin-top: 0.75rem; }

  .notify-popup .newsletter-form__message {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }
  .notify-popup .newsletter-form__message--success { color: #28a745; }
  .notify-popup .newsletter-form__message svg { width: 16px; height: 16px; }
</style>

<div class="notify-popup-overlay" data-notify-overlay></div>

<div class="notify-popup" data-notify-popup role="dialog" aria-modal="true">
  <div class="notify-popup__header">
    <h3 class="notify-popup__title">{{ 'products.product.notify_me' | t }}</h3>
    <button type="button" class="notify-popup__close" data-notify-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="notify-popup__body">
    <div class="notify-popup__product">
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 140 | image_tag: class: 'notify-popup__product-image', loading: 'lazy' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'notify-popup__product-image' }}
      {%- endif -%}
      <div>
        <h4 class="notify-popup__product-title">{{ product.title }}</h4>
        {%- if current_variant.title != 'Default Title' -%}
          <p class="notify-popup__product-variant" data-notify-variant-display>{{ current_variant.title }}</p>
        {%- endif -%}
      </div>
    </div>

    <p class="notify-popup__description">{{ 'products.product.notify_description' | t }}</p>

    {%- comment -%} Newsletter-style form - Same structure that creates customers {%- endcomment -%}
    {% form 'customer', class: 'newsletter-form notify-form' %}
      <input type="hidden" name="contact[tags]" value="back-in-stock, {{ notify_tag }}" data-notify-tags>

      <div class="newsletter-form__field-wrapper">
        <div class="field">
          <label class="field__label" for="NotifyForm--{{ unique_id }}">
            {{ 'customer.register.email' | t }} *
          </label>
          <input
            id="NotifyForm--{{ unique_id }}"
            type="email"
            name="contact[email]"
            class="field__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Notify-error--{{ unique_id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Notify-success--{{ unique_id }}"
            {% endif %}
            placeholder="Enter your email"
            required
            data-notify-email
          >
        </div>
        {%- if form.errors -%}
          <small class="newsletter-form__message form__message" id="Notify-error--{{ unique_id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="15" y1="9" x2="9" y2="15"></line>
              <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </small>
        {%- endif -%}
      </div>

      {%- if form.posted_successfully? -%}
        <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Notify-success--{{ unique_id }}" tabindex="-1" autofocus>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          {{ 'products.product.notify_success_title' | t }}
        </h3>
      {%- else -%}
        <button type="submit" class="notify-popup__submit" name="commit">
          {{ 'products.product.notify_button' | t }}
        </button>
        <p class="notify-popup__privacy">{{ 'products.product.notify_privacy' | t }}</p>
      {%- endif -%}
    {% endform %}
  </div>
</div>

<script>
(function() {
  var overlay = document.querySelector('[data-notify-overlay]');
  var popup = document.querySelector('[data-notify-popup]');
  var closeBtn = document.querySelector('[data-notify-close]');

  var currentVariantId = '{{ variant_id }}';
  var currentVariantTitle = '{{ variant_title | escape }}';
  var productHandle = '{{ product_handle }}';

  if (!overlay || !popup) return;

  window.openNotifyPopup = function(variantId, variantTitle) {
    currentVariantId = variantId || currentVariantId;
    currentVariantTitle = variantTitle || currentVariantTitle;

    var variantDisplay = document.querySelector('[data-notify-variant-display]');
    if (variantTitle && variantDisplay) {
      variantDisplay.textContent = variantTitle;
    }

    // Update tags field with current variant
    var tagsField = document.querySelector('[data-notify-tags]');
    if (tagsField) {
      tagsField.value = 'back-in-stock, notify-' + productHandle + '-' + currentVariantId;
    }

    overlay.classList.add('active');
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';

    var emailInput = popup.querySelector('[data-notify-email]');
    if (emailInput) {
      setTimeout(function() { emailInput.focus(); }, 100);
    }
  };

  function closePopup() {
    overlay.classList.remove('active');
    popup.classList.remove('active');
    document.body.style.overflow = '';
  }

  window.closeNotifyPopup = closePopup;

  if (closeBtn) {
    closeBtn.addEventListener('click', closePopup);
  }

  overlay.addEventListener('click', closePopup);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && popup.classList.contains('active')) closePopup();
  });

  // Auto-open popup if form was just submitted successfully (page reloaded)
  var successMsg = popup.querySelector('.newsletter-form__message--success');
  if (successMsg) {
    overlay.classList.add('active');
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';

    // Save to localStorage for tracking
    try {
      var emailInput = popup.querySelector('[data-notify-email]');
      var subs = JSON.parse(localStorage.getItem('back_in_stock_subs') || '[]');
      subs.push({
        product: productHandle,
        variantId: currentVariantId,
        variantTitle: currentVariantTitle,
        tag: 'notify-' + productHandle + '-' + currentVariantId,
        date: new Date().toISOString()
      });
      localStorage.setItem('back_in_stock_subs', JSON.stringify(subs));
    } catch(e) {}

    // Auto close after 3 seconds
    setTimeout(closePopup, 3000);
  }
})();
</script>
