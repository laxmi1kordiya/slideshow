{"sections":{"image_with_text_overlay_9paWG3":{"type":"image-with-text-overlay","name":"t:sections.image_with_text_overlay.presets.image_with_text_overlay.name","settings":{"color_scheme":"","image_size":"lg","image":"shopify:\/\/shop_images\/IMG_0003_2-2_03d59a77-5d10-4e1b-a104-c37f6b7596d8.jpg","mobile_image":"shopify:\/\/shop_images\/Asparagus_With_Summer_Truffles.jpg","allow_transparent_header":false,"reveal_on_scroll":true,"remove_vertical_spacing":true,"content_width":"md","mobile_text_position":"place-self-center text-center","desktop_text_position":"sm:place-self-center sm:text-center","overlay_color":"#000000","overlay_opacity":0}},"main":{"type":"main-article","disabled":true,"settings":{"color_scheme":"","show_image":true,"enable_parallax":true,"image_size":"medium","content_width":"xs","show_date":false,"show_category":false,"show_author":false,"show_share_buttons":false,"show_sticky_bar":false,"toolbar_color_scheme":""}},"image_with_text_7cHCBe":{"type":"image-with-text","blocks":{"richtext_FmqFTV":{"type":"richtext","settings":{"content":"<h1>ASPARAGUS WITH SUMMER TRUFFLES<\/h1>"}}},"block_order":["richtext_FmqFTV"],"disabled":true,"settings":{"color_scheme":"scheme-3","separate_section_with_border":true,"image":"shopify:\/\/shop_images\/EB984EC9-8F56-420E-B492-A3555E552106_1_201_a.jpg","reveal_on_scroll":true,"image_position":"end","content_width":"sm","remove_vertical_spacing":true}},"rich_text_qapXHx":{"type":"rich-text","blocks":{"richtext_8BTPyU":{"type":"richtext","settings":{"content":"<h3><strong>ASPARAGUS WITH FRESH SUMMER TRUFFLES<\/strong><\/h3>"}},"subheading_Y78fAJ":{"type":"subheading","settings":{"text":"<strong>Servings:<\/strong> 2 as a Starter <strong>Prep Time:<\/strong> 10 minutes <strong>Cook Time: <\/strong>10 minutes"}}},"block_order":["richtext_8BTPyU","subheading_Y78fAJ"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"rich_text_cXPwW7":{"type":"rich-text","blocks":{"heading_AJMbTn":{"type":"heading","settings":{"text":"<strong>INGREDIENTS<\/strong>","heading_tag":"h4"}},"richtext_xXJnzy":{"type":"richtext","settings":{"content":"<ul><li>400g Trimmed Asparagus<\/li><li>50g Summer Truffle<\/li><li>50g Shaved Parmesan<\/li><li>10ml White Balsamic Vinegar<\/li><li>30ml Black Truffle Oil <\/li><li>Olive Oil<\/li><li>Seasoning<\/li><\/ul>"}},"subheading_e39Cfw":{"type":"subheading","settings":{"text":"<strong>EQUIPMENT<\/strong>"}},"richtext_kVGwyx":{"type":"richtext","settings":{"content":"<ul><li>Large saucepan<\/li><li>Bowl of iced water<\/li><li>Truffle slicer<\/li><li>Glass jar with lid<\/li><li>Medium size non-stick frying pan<\/li><\/ul>"}}},"block_order":["heading_AJMbTn","richtext_xXJnzy","subheading_e39Cfw","richtext_kVGwyx"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"rich_text_znVA7E":{"type":"rich-text","blocks":{"richtext_fgdHqk":{"type":"richtext","settings":{"content":"<p>There are few vegetables that stand alone as well as Asparagus. In France '<em><strong>le légume royal' <\/strong><\/em>is often served as a starter with a simple vinaigrette, in Italy it is served with Parma ham.<\/p><p>Steamed, roasted or grilled these delicious spring stems are super versatile and marry well with a host of other fantastic ingredients. <\/p>"}},"heading_F6BnFW":{"type":"heading","settings":{"text":"<strong>METHOD<\/strong>","heading_tag":"h4"}},"richtext_wCyiME":{"type":"richtext","settings":{"content":"<p>Bring a large saucepan of water to the boil, add a good punch of salt. Blanch the asparagus for 4 minutes in rapidly boiling water, then remove using tongs or a slotted spoon and place straight in the ice bath to stop them cooking further, Hold for two minutes then remove and place on kitchen paper to dry.<\/p><p>Place frying pan over a moderate heat, add a splash of olive oil then the asparagus and gently fry for 2-3 minutes turning often. The objective is to gently caramelize the skin not to overcook the asparagus. Once a light golden colour is achieved remove the pan from the heat, season and set aside.<\/p><p>Place the asparagus spears evenly on each plate. <\/p><p>Shake the jar of vinaigrette vigorously until it has emulsified (20-30 seconds) then spoon over the asparagus.<\/p><p>With the truffle slicer, shave the truffles (as thinly as possible) in abundance over the asparagus, using the same slicer shave over the parmesan. <\/p><p>Add a sprinkle of salt then serve.<\/p>"}}},"block_order":["richtext_fgdHqk","heading_F6BnFW","richtext_wCyiME"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"image_with_text_QEDHGF":{"type":"image-with-text","blocks":{"heading_wDhig8":{"type":"heading","settings":{"text":"Image with text","heading_tag":"h1"}},"subheading_cAF6yT":{"type":"subheading","settings":{"text":"Subheading"}}},"block_order":["heading_wDhig8","subheading_cAF6yT"],"disabled":true,"settings":{"color_scheme":"scheme-3","separate_section_with_border":true,"reveal_on_scroll":true,"image_position":"start","content_width":"sm","remove_vertical_spacing":true}},"prev-next-blog-posts":{"type":"prev-next-blog-posts","disabled":true,"settings":{"color_scheme":"","separate_section_with_border":false,"subheading":"","title":"Read more","show_category":false,"show_excerpt":true,"show_read_more":true}},"featured_collections_UpEBPk":{"type":"featured-collections","blocks":{"collection_qpkgLN":{"type":"collection","settings":{"collection":"asparagus-with-summer-truffle","products_count":50,"title":"<strong>SHOP INGREDIENTS<\/strong>","link_url":"","link_text":"View all"}}},"block_order":["collection_qpkgLN"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"hide_product_information":false,"stack_products":false,