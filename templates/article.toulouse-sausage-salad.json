{"sections":{"main":{"type":"main-article","disabled":true,"settings":{"color_scheme":"","show_image":true,"enable_parallax":true,"image_size":"medium","content_width":"xs","show_date":false,"show_category":false,"show_author":false,"show_share_buttons":false,"show_sticky_bar":false,"toolbar_color_scheme":""}},"image_with_text_7cHCBe":{"type":"image-with-text","blocks":{"heading_dkUdwh":{"type":"heading","settings":{"text":"<strong>TOULOUSE SAUSAGE & TOMATO SALAD<\/strong>","heading_tag":"h3"}}},"block_order":["heading_dkUdwh"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"image":"shopify:\/\/shop_images\/C1D451B9-58E9-4842-B4F0-D5FA6E9B7895_1_201_a.jpg","reveal_on_scroll":true,"image_position":"end","content_width":"sm","remove_vertical_spacing":true}},"rich_text_qapXHx":{"type":"rich-text","blocks":{"subheading_Y78fAJ":{"type":"subheading","settings":{"text":"<strong>Servings:<\/strong> 4 Main Course <strong>Prep Time: <\/strong>15 Mins <strong>Cook Time:<\/strong> 30 Mins <strong>Total: <\/strong>45 Mins"}}},"block_order":["subheading_Y78fAJ"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"rich_text_cXPwW7":{"type":"rich-text","blocks":{"heading_AJMbTn":{"type":"heading","settings":{"text":"<strong>INGREDIENTS<\/strong>","heading_tag":"h4"}},"richtext_xXJnzy":{"type":"richtext","settings":{"content":"<ul><li>500g Toulouse Sausage<\/li><li>600g Provence Tomatoes<\/li><li>300g Waxy Potatoes such as Linzer, La Ratte or Noirmoutier<\/li><li>2 Salad Onions<\/li><li>1 Large Handful of Rocket<\/li><li>1 Handful of Chopped Fresh Herbs such as Parsley, Chervil & Oregano<\/li><li>Salt & Pepper<\/li><\/ul>"}},"heading_Mh9rpy":{"type":"heading","settings":{"text":"<strong>TRUFFLE MUSTARD DRESSING<\/strong>","heading_tag":"h4"}},"richtext_WeAMqN":{"type":"richtext","settings":{"content":"<ul><li>2 Tbsp Extra Virgin Olive Oil <\/li><li>2 Tbsp Black Truffle Oil<\/li><li>2 Tsp White Balsamic Vinegar<\/li><li>2 Tsp Wholegrain Pommery Mustard<\/li><li>Salt & Pepper<\/li><\/ul>"}}},"block_order":["heading_AJMbTn","richtext_xXJnzy","heading_Mh9rpy","richtext_WeAMqN"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"rich_text_znVA7E":{"type":"rich-text","blocks":{"richtext_fgdHqk":{"type":"richtext","settings":{"content":"<p>This truly delicious recipe makes for a perfect laid back summer lunch to be enjoyed over a bottle of red wine. We have used Toulouse sausages in this recipe, however other good quality sausages will also work well. It is also possible to supplement the salad onions for other onions such as Roscoff, red onion or shallot.<\/p>"}},"heading_F6BnFW":{"type":"heading","settings":{"text":"<strong>METHOD<\/strong>","heading_tag":"h4"}},"subheading_EBUadW":{"type":"subheading","settings":{"text":"<strong>STEP ONE<\/strong>"}},"richtext_wCyiME":{"type":"richtext","settings":{"content":"<p>Lightly drizzle the sausages with olive oil and roast in the oven at 170°c for 25-30 minutes or until cooked through and nicely coloured on the outside.  Allow to cool slightly and slice on an angle.<\/p>"}},"subheading_jFKiGa":{"type":"subheading","settings":{"text":"<strong>STEP TWO<\/strong>"}},"richtext_aiWfcR":{"type":"richtext","settings":{"content":"<p>While the sausages are cooking place the potatoes in a medium sized pan and fill with water and a pinch of salt.  Bring to the boil and reduce to a simmer for 15-20 minutes or until you can just pierce through with a knife.  Drain and allow to cool enough to handle.  Using a knife, gently scrape off and discard the skins.  Slice the potatoes lengthways into 0.5cm slices, drizzle with olive oil, season and set aside.<\/p>"}},"subheading_V6HaWq":{"type":"subheading","settings":{"text":"<strong>STEP THREE<\/strong>"}},"richtext_Nphrre":{"type":"richtext","settings":{"content":"<p>Measure the dressing ingredients into an empty jam jar and shake well with the lid on to mix<\/p>"}},"subheading_RCkJU9":{"type":"subheading","settings":{"text":"<strong>STEP FOUR<\/strong>"}},"richtext_MxR8XD":{"type":"richtext","settings":{"content":"<p>Slice the onions and give them a quick rinse in a sieve under cold water to wash out the acid and calm the onion taste slightly.<\/p>"}},"subheading_AnwCpk":{"type":"subheading","settings":{"text":"<strong>STEP FIVE<\/strong>"}},"richtext_gmXmFP":{"type":"richtext","settings":{"content":"<p>Slice the tomatoes and chop the fresh herbs.<\/p><p>Place all the ingredients in a large bowl and gently toss, adjusting the seasoning if necessary.  Arrange onto four plates and serve.<\/p>"}}},"block_order":["richtext_fgdHqk","heading_F6BnFW","subheading_EBUadW","richtext_wCyiME","subheading_jFKiGa","richtext_aiWfcR","subheading_V6HaWq","richtext_Nphrre","subheading_RCkJU9","richtext_MxR8XD","subheading_AnwCpk","richtext_gmXmFP"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"content_width":"sm","text_position":"center","remove_vertical_spacing":false}},"prev-next-blog-posts":{"type":"prev-next-blog-posts","disabled":true,"settings":{"color_scheme":"","separate_section_with_border":false,"subheading":"","title":"Read more","show_category":false,"show_excerpt":true,"show_read_more":true}},"featured_collections_UpEBPk":{"type":"featured-collections","blocks":{"collection_qpkgLN":{"type":"collection","settings":{"collection":"toulouse-sausage-salad","products_count":50,"title":"SHOP INGREDIENTS","link_url":"","link_text":"View all"}}},"block_order":["collection_qpkgLN"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"hide_product_information":false,"stack_products":false,"products_per_row_mobile":"2","products_per_row_desktop":3,"horizontal_spacing_factor":0.5,"vertical_spacing_factor":0.5,"subheading":""}},"featured_collections_bwVUaA":{"type":"featured-collections","blocks":{"collection_TnGf7W":{"type":"collection","settings":{"collection":"butchery","products_count":50,"title":"","link_url":"","link_text":"View all"}}},"block_order":["collection_TnGf7W"],"settings":{"color_scheme":"scheme-2","separate_section_with_border":false,"hide_product_information":false,"stack_products":false,"products_per_row_mobile":"2","products_per_row_desktop":3,"horizontal_spacing_factor":0.5,"vertical_spacing_factor":0.5,"subheading":""}}},"order":["main","image_with_text_7cHCBe","rich_text_qapXHx","rich_text_cXPwW7","rich_text_znVA7E","prev-next-blog-posts","featured_collections_UpEBPk","featured_collections_bwVUaA"]}